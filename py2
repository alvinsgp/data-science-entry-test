# create a list of numbers
lst = [1, 2, 3, 4, 5]
print("Original:", lst)

replace_val = 0

# Replace every element (returns a new list)
new_all = [replace_val for _ in lst]
print("All replaced (new):", new_all)

target = 3
replaced = [replace_val if x == target else x for x in lst]
print(f"Replace only {target} with {replace_val}:", replaced)
